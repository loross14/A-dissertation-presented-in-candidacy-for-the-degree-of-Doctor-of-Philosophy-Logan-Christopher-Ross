{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/rongorongo", "destination": "/essays/deciphering-rongorongo", "permanent": true },
    { "source": "/matrix/tensor-network-contraction/:slug", "destination": "/matrix/tensor-network-contraction", "permanent": true },
    { "source": "/matrix/vector-databases-rag/:slug", "destination": "/matrix/vector-databases-rag", "permanent": true },
    { "source": "/matrix/neural-network-states/:slug", "destination": "/matrix/neural-network-states", "permanent": true },
    { "source": "/matrix/biological-connectomes/:slug", "destination": "/matrix/biological-connectomes", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*).pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
